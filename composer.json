{
    "name": "laravel-skir/runtime",
    "description": "PHP runtime support for Skir serialization and descriptors.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Maxim Kerstens",
            "email": "maxim.kerstens@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "LaravelSkir\\Runtime\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelSkir\\Runtime\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "format": "pint",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

